<UserControl x:Class="V_Launcher.Views.ExecutableManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:V_Launcher.Views"
             xmlns:vm="clr-namespace:V_Launcher.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:ExecutableManagementViewModel}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Import converters -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Styles for consistent UI -->
            <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>
            
            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,5,0,2"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            
            <Style x:Key="InputStyle" TargetType="Control">
                <Setter Property="Margin" Value="0,2,0,8"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="MinHeight" Value="30"/>
            </Style>
            
            <Style x:Key="ButtonStyle" TargetType="Button">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="15,8"/>
                <Setter Property="MinWidth" Value="80"/>
            </Style>
            
            <Style x:Key="BrowseButtonStyle" TargetType="Button">
                <Setter Property="Margin" Value="5,2,0,8"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="MinWidth" Value="60"/>
                <Setter Property="Content" Value="Browse..."/>
            </Style>
            
            <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="Red"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,5"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
            
            <Style x:Key="IconPreviewStyle" TargetType="Image">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Stretch" Value="Uniform"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Executable Configuration Management" 
                   Style="{StaticResource HeaderTextStyle}"/>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Configuration List -->
            <GroupBox Grid.Column="0" Header="Configured Applications" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Configuration ListBox -->
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Configurations}"
                             SelectedItem="{Binding SelectedConfiguration}"
                             SelectionMode="Single"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Icon placeholder -->
                                    <Border Grid.Column="0" 
                                            Width="32" 
                                            Height="32" 
                                            Margin="0,0,8,0"
                                            Background="LightGray"
                                            CornerRadius="2">
                                        <TextBlock Text="📱" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"
                                                   FontSize="16"/>
                                    </Border>
                                    
                                    <!-- Configuration Info -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayName}" 
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ExecutablePath}" 
                                                   FontSize="11" 
                                                   Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" 
                                                   Foreground="Gray">
                                            <Run Text="Account: "/>
                                            <Run Text="{Binding ADAccountId, StringFormat='ID: {0}'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <!-- Configuration Action Buttons -->
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <Button Content="Add New" 
                                Command="{Binding AddConfigurationCommand}"
                                Style="{StaticResource ButtonStyle}"/>
                        <Button Content="Edit" 
                                Command="{Binding EditConfigurationCommand}"
                                Style="{StaticResource ButtonStyle}"/>
                        <Button Content="Delete" 
                                Command="{Binding DeleteConfigurationCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                    <Setter Property="Background" Value="#FFE74C3C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </GroupBox>
            
            <!-- Configuration Form -->
            <GroupBox Grid.Column="2" 
                      Header="Configuration Details"
                      Padding="15"
                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Display Name -->
                        <TextBlock Text="Display Name:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 TabIndex="1"/>
                        
                        <!-- Executable Path -->
                        <TextBlock Text="Executable Path:" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"
                                     TabIndex="2"/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseExecutableCommand}"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    TabIndex="3"/>
                        </Grid>
                        
                        <!-- AD Account Selection -->
                        <TextBlock Text="AD Account:" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AvailableAccounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  Style="{StaticResource InputStyle}"
                                  TabIndex="4">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Username}" FontSize="11" Foreground="Gray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <!-- Custom Icon Path -->
                        <TextBlock Text="Custom Icon (Optional):" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding CustomIconPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"
                                     TabIndex="5"/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseCustomIconCommand}"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    TabIndex="6"/>
                            <Button Grid.Column="2"
                                    Content="Clear"
                                    Command="{Binding ClearCustomIconCommand}"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    TabIndex="7"/>
                        </Grid>
                        
                        <!-- Icon Preview -->
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,5">
                            <TextBlock Text="Preview:" 
                                       Style="{StaticResource LabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Image Source="{Binding PreviewIcon}"
                                   Style="{StaticResource IconPreviewStyle}"/>
                        </StackPanel>
                        
                        <!-- Arguments (Optional) -->
                        <TextBlock Text="Command Line Arguments (Optional):" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 TabIndex="8"/>
                        
                        <!-- Working Directory -->
                        <TextBlock Text="Working Directory (Optional):" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"
                                     TabIndex="9"/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseWorkingDirectoryCommand}"
                                    Content="Browse..."
                                    Style="{StaticResource BrowseButtonStyle}"
                                    TabIndex="10"/>
                        </Grid>
                        
                        <!-- Validation Message -->
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Style="{StaticResource ErrorTextStyle}"
                                   Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        
                        <!-- Form Buttons -->
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    Margin="0,20,0,0">
                            <Button Content="Save" 
                                    Command="{Binding SaveConfigurationCommand}"
                                    TabIndex="11">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                        <Setter Property="Background" Value="#FF27AE60"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Cancel" 
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource ButtonStyle}"
                                    TabIndex="12"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
        
        <!-- Loading Indicator -->
        <Grid Grid.Row="2" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              HorizontalAlignment="Center"
              Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" 
                             Width="200" 
                             Height="20"
                             Margin="0,0,10,0"/>
                <TextBlock Text="Loading..." 
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>