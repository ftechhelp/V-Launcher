<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:V_Launcher.Views">
    
    <!-- Boolean to Visibility Converter -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    
    <!-- Inverse Boolean to Visibility Converter -->
    <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    
    <!-- Boolean to Edit Mode Text Converter -->
    <local:BoolToEditModeConverter x:Key="BoolToEditModeConverter"/>
    
</ResourceDictionary>