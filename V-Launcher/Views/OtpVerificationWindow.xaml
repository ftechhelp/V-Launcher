<Window x:Class="V_Launcher.Views.OtpVerificationWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="V-Launcher - Authentication Required"
        Height="280"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Icon="/V-Launcher_Logo.ico">
    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Two-Factor Authentication"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,10"/>

        <!-- Instructions -->
        <TextBlock Grid.Row="1"
                   Text="Enter the 6-digit code from your authenticator app:"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"/>

        <!-- Code Entry -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBox x:Name="CodeTextBox"
                     Width="200"
                     Height="44"
                     FontSize="24"
                     FontFamily="Consolas"
                     TextAlignment="Center"
                     MaxLength="6"
                     VerticalContentAlignment="Center"
                     BorderBrush="{StaticResource MediumGrayBrush}"
                     BorderThickness="2"
                     KeyDown="CodeTextBox_KeyDown"/>
        </StackPanel>

        <!-- Error Message -->
        <TextBlock Grid.Row="3"
                   x:Name="ErrorMessageTextBlock"
                   Foreground="{StaticResource ErrorRedBrush}"
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   VerticalAlignment="Top"
                   Margin="0,5,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="VerifyButton"
                    Content="Verify"
                    Width="100"
                    Height="36"
                    Margin="0,0,10,0"
                    Background="{StaticResource PrimaryRedBrush}"
                    Foreground="{StaticResource PrimaryWhiteBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="VerifyButton_Click"/>
            <Button x:Name="ExitButton"
                    Content="Exit"
                    Width="80"
                    Height="36"
                    Background="{StaticResource MediumGrayBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="0"
                    IsCancel="True"
                    Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
