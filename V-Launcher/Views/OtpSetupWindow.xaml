<Window x:Class="V_Launcher.Views.OtpSetupWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Set Up Two-Factor Authentication - Required"
Height="662"
Width="516"
WindowStartupLocation="CenterScreen"
ResizeMode="NoResize"
WindowStyle="SingleBorderWindow"
Icon="/V-Launcher_Logo.ico"
Closing="Window_Closing">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Title -->
		<TextBlock Grid.Row="0"
                   Text="Set Up Authenticator App"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,4"/>

		<!-- Required Notice -->
		<TextBlock Grid.Row="0"
                   Text="Two-factor authentication is required to use V-Launcher."
                   Foreground="{StaticResource ErrorRedBrush}"
                   FontWeight="SemiBold"
                   FontSize="12"
                   Margin="0,28,0,10"/>

		<!-- Instructions -->
		<TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,15">
            <Run Text="1. Open "/>
            <Run Text="Microsoft Authenticator" FontWeight="SemiBold"/>
            <Run Text=" (or any TOTP app) on your phone."/>
            <LineBreak/>
            <Run Text="2. Scan the QR code below or enter the secret key manually."/>
            <LineBreak/>
            <Run Text="3. Enter the 6-digit code from the app to verify setup."/>
		</TextBlock>

		<!-- QR Code -->
		<Border Grid.Row="2"
                HorizontalAlignment="Center"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,10">
			<Image x:Name="QrCodeImage"
                   Width="200"
                   Height="200"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
		</Border>

		<!-- Manual Secret Key -->
		<StackPanel Grid.Row="3" Margin="0,0,0,15">
			<TextBlock Text="Or enter this key manually:"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       Margin="0,0,0,5"/>
			<Border Background="{StaticResource LightGrayBrush}"
                    CornerRadius="4"
                    Padding="10,8"
                    HorizontalAlignment="Center">
				<TextBlock x:Name="SecretKeyTextBlock"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
			</Border>
		</StackPanel>

		<!-- Separator -->
		<Separator Grid.Row="4" Margin="0,0,0,15"/>

		<!-- Verification -->
		<TextBlock Grid.Row="5"
                   Text="Enter the 6-digit code from your authenticator app:"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

		<StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
			<TextBox x:Name="VerificationCodeTextBox"
                     Width="180"
                     Height="40"
                     FontSize="22"
                     FontFamily="Consolas"
                     TextAlignment="Center"
                     MaxLength="6"
                     VerticalContentAlignment="Center"
                     BorderBrush="{StaticResource MediumGrayBrush}"
                     BorderThickness="2"
                     Margin="0,0,10,0"/>
		</StackPanel>

		<!-- Error Message -->
		<TextBlock Grid.Row="7"
                   x:Name="ErrorMessageTextBlock"
                   Foreground="{StaticResource ErrorRedBrush}"
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,0,0,10"/>

		<!-- Buttons -->
		<StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
			<Button x:Name="VerifyButton"
                    Content="Verify &amp; Continue"
                    Width="130"
                    Height="36"
                    Margin="0,0,10,0"
                    Background="{StaticResource PrimaryRedBrush}"
                    Foreground="{StaticResource PrimaryWhiteBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="VerifyButton_Click"/>
			<Button x:Name="ExitAppButton"
                    Content="Exit App"
                    Width="80"
                    Height="36"
                    Background="{StaticResource MediumGrayBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Click="ExitAppButton_Click"/>
		</StackPanel>
	</Grid>
</Window>
