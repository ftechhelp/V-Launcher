<UserControl x:Class="V_Launcher.Views.CredentialManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:V_Launcher.Views"
             xmlns:vm="clr-namespace:V_Launcher.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:CredentialManagementViewModel}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Import converters -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Styles for consistent UI -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
        
        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="AD Account Management" 
                   Style="{StaticResource HeaderTextStyle}"/>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Account List -->
            <GroupBox Grid.Column="0" Header="Saved Accounts" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Account ListBox -->
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Accounts}"
                             SelectedItem="{Binding SelectedAccount}"
                             SelectionMode="Single"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" 
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Username}" 
                                               FontSize="11" 
                                               Foreground="Gray"/>
                                    <TextBlock Text="{Binding Domain}" 
                                               FontSize="11" 
                                               Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <!-- Account Action Buttons -->
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <Button Content="Add New" 
                                Command="{Binding AddAccountCommand}"
                                Style="{StaticResource ButtonStyle}"/>
                        <Button Content="Edit" 
                                Command="{Binding EditAccountCommand}"
                                Style="{StaticResource ButtonStyle}"/>
                        <Button Content="Delete" 
                                Command="{Binding DeleteAccountCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                    <Setter Property="Background" Value="#FFE74C3C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </GroupBox>
            
            <!-- Account Form -->
            <GroupBox Grid.Column="2" 
                      Header="{Binding IsEditing, Converter={StaticResource BoolToEditModeConverter}}"
                      Padding="15"
                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Display Name -->
                        <TextBlock Text="Display Name:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 TabIndex="1"/>
                        
                        <!-- Username -->
                        <TextBlock Text="Username:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 TabIndex="2"/>
                        
                        <!-- Domain -->
                        <TextBlock Text="Domain:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 TabIndex="3"/>
                        
                        <!-- Password -->
                        <TextBlock Text="Password:" Style="{StaticResource LabelStyle}"/>
                        <local:SecurePasswordBox SecurePassword="{Binding Password, Mode=TwoWay}"
                                                 Style="{StaticResource InputStyle}"
                                                 TabIndex="4"/>
                        
                        <!-- Confirm Password -->
                        <TextBlock Text="Confirm Password:" Style="{StaticResource LabelStyle}"/>
                        <local:SecurePasswordBox SecurePassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                                 Style="{StaticResource InputStyle}"
                                                 TabIndex="5"/>
                        
                        <!-- Validation Message -->
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Style="{StaticResource ErrorTextStyle}"
                                   Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        
                        <!-- Form Buttons -->
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    Margin="0,20,0,0">
                            <Button Content="Save" 
                                    Command="{Binding SaveAccountCommand}"
                                    TabIndex="6">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                        <Setter Property="Background" Value="#FF27AE60"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Cancel" 
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource ButtonStyle}"
                                    TabIndex="7"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
        
        <!-- Loading Indicator -->
        <Grid Grid.Row="2" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              HorizontalAlignment="Center"
              Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" 
                             Width="200" 
                             Height="20"
                             Margin="0,0,10,0"/>
                <TextBlock Text="Loading..." 
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>